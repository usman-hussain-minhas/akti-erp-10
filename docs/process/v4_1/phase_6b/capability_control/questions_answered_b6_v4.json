  "canonical_hard_rule_doctrine": {
    "principle": "An edge is hard only if it is immovable: platform identity or architecture, transaction/data integrity, security/regulatory enforcement, billing/evidence structure, or customer-protection asymmetry. Structure is hard; values and policies not named hard are configurable as data.",
    "platform_hard_rule_set": [
      {
        "id": "A",
        "name": "Platform Identity and Architecture",
        "rule": "Platform-neutral identity, two-frontend separation, services as architecture units, Foundry as activation source of truth, and one-way service-to-core dependency direction are hard."
      },
      {
        "id": "B",
        "name": "Transaction and Data Integrity",
        "rule": "Saga/no-2PC, at-least-once with idempotent consumers, provider-aware idempotency, locked 24-hour dedup window, immutable invoices after generation, and soft-delete plus staged permanent deletion are hard."
      },
      {
        "id": "C",
        "name": "Security and Identity",
        "rule": "No default credentials, MFA floors for privileged/financial roles, audited support-window access, and shared Person/Identity Graph anchoring are hard."
      },
      {
        "id": "D",
        "name": "Billing and Evidence",
        "rule": "Micro-service pricing reference, usage evidence including zero-priced evidence, and prepaid balance as funds source of truth are hard structures."
      },
      {
        "id": "E",
        "name": "Customer-First Protection",
        "rule": "Two-phase uninstall, minimum protection window, reminders before permanent deletion, and free restore inside the protection window are hard."
      },
      {
        "id": "F",
        "name": "25-Year Design Principles",
        "rule": "Design values guide the hard rules but are not independent binary gates unless expressed through a concrete platform rule or ADL."
      },
      {
        "id": "G",
        "name": "Configurability Rule",
        "rule": "Everything not named hard is configurable as data through Super Admin or approved configuration surfaces without code or ADR."
      },
      {
        "id": "H",
        "name": "Communication Gateway Opt-Out",
        "rule": "All outbound communication send attempts pass through the Communication Gateway and global opt-out enforcement under ADL-004. This is scoped to send paths only."
      }
    ],
    "adl_registry_scope_note": "Domain behavioral ADLs, including ADL-013 through ADL-024 and ADL-016 FX gain/loss, remain hard through the ADL registry. This artifact defines the platform hard-rule layer and does not replace the ADL registry."
  },
  "basis_decision_tree": [
    {
      "order": 1,
      "rule": "If an edge is named by a specific ADL, use adl_hard_rule and carry non-empty adl_refs."
    },
    {
      "order": 2,
      "rule": "If an edge is a locked platform rule and not ADL-specific, use business_logic_hard_rule."
    },
    {
      "order": 3,
      "rule": "If the target is billing/evidence-bearing, use billing_or_evidence_required."
    },
    {
      "order": 4,
      "rule": "If the edge is the Foundry/manifest activation dependency to seed_6a_service_manifest_contract, use activation_lifecycle_required."
    },
    {
      "order": 5,
      "rule": "If the dependency is configurable and not immovable, represent it as soft, conditional, or deferred. Do not silently drop it."
    },
    {
      "order": 6,
      "rule": "If genuinely unclassifiable from source, keep manual_review_required and do not promote ticket execution."
    }
  ],
