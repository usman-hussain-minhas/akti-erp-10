{
  "screen_key": "phase6.runtime-capability-shell",
  "module_key": "phase6.runtime",
  "title": "Runtime Capability Shell",
  "route": "/app/phase-6/runtime-capabilities",
  "screen_type": "private_portal",
  "status": "planned",
  "version": "0.1.0",
  "business_purpose": "Show which Phase 6A-6C runtime capabilities are available for the signed-in tenant and prevent inactive services from being exposed as usable screens.",
  "primary_user_context": "Tenant operator reviewing the activated Phase 6A-6C capability surface before opening runtime workflows.",
  "user_goal": "See active services, understand unavailable services, and open only the capabilities that Foundry activation allows.",
  "success_outcome": "Activated services are visible and reachable while inactive services are hidden from navigation and blocked server-side if directly requested.",
  "required_capabilities": [
    "phase6.runtime-capability-shell.view"
  ],
  "optional_capabilities": [
    "phase6.runtime-capability-shell.open-active-service",
    "phase6.runtime-capability-shell.refresh-status"
  ],
  "visibility_rules": [
    {
      "key": "phase6.runtime-capability-shell.visible",
      "description": "Show the runtime capability shell only to users with the Phase 6 runtime shell view capability.",
      "capability_key": "phase6.runtime-capability-shell.view"
    },
    {
      "key": "phase6.runtime-capability-shell.active-services-only",
      "description": "Show service navigation only when Foundry activation marks that service active for the tenant.",
      "capability_key": "phase6.runtime-capability-shell.open-active-service"
    }
  ],
  "record_scope_behavior": {
    "default_scope": "organization",
    "allowed_scope_types": [
      "organization"
    ],
    "description": "The shell is organization-scoped and must never use data from another tenant when calculating activation, navigation, or route access."
