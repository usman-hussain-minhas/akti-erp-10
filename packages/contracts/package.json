{
  "name": "@akti/contracts",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    "./gatekeeper-contract": {
      "types": "./dist/gatekeeper-contract.d.ts",
      "default": "./dist/gatekeeper-contract.js"
    }
  },
  "typesVersions": {
    "*": {
      "gatekeeper-contract": [
        "gatekeeper-contract.ts"
      ]
    }
