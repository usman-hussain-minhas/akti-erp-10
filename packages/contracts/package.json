{
  "name": "@akti/contracts",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    "./access-core-capability-seed": {
      "types": "./dist/access-core-capability-seed.contract.d.ts",
      "default": "./dist/access-core-capability-seed.contract.js"
    },
    "./access-core-module-manifest": {
      "types": "./dist/access-core.module-manifest.contract.d.ts",
      "default": "./dist/access-core.module-manifest.contract.js"
    },
    "./engagement-gateway-lite": {
      "types": "./dist/engagement-gateway-lite.contract.d.ts",
      "default": "./dist/engagement-gateway-lite.contract.js"
    },
    "./engagement-gateway-lite-module-manifest": {
      "types": "./dist/engagement-gateway-lite.module-manifest.contract.d.ts",
      "default": "./dist/engagement-gateway-lite.module-manifest.contract.js"
    },
    "./lead-desk-core": {
      "types": "./dist/lead-desk-core.contract.d.ts",
      "default": "./dist/lead-desk-core.contract.js"
    },
    "./lead-desk-core-module-manifest": {
      "types": "./dist/lead-desk-core.module-manifest.contract.d.ts",
      "default": "./dist/lead-desk-core.module-manifest.contract.js"
    },
    "./gatekeeper-contract": {
      "types": "./dist/gatekeeper-contract.d.ts",
      "default": "./dist/gatekeeper-contract.js"
    }
  },
  "typesVersions": {
    "*": {
      "access-core-capability-seed": [
        "access-core-capability-seed.contract.ts"
      ],
      "access-core-module-manifest": [
        "access-core.module-manifest.contract.ts"
      ],
      "engagement-gateway-lite": [
        "engagement-gateway-lite.contract.ts"
      ],
      "engagement-gateway-lite-module-manifest": [
        "engagement-gateway-lite.module-manifest.contract.ts"
      ],
      "lead-desk-core": [
        "lead-desk-core.contract.ts"
      ],
      "lead-desk-core-module-manifest": [
        "lead-desk-core.module-manifest.contract.ts"
      ],
      "gatekeeper-contract": [
        "gatekeeper-contract.ts"
      ]
    }
  },
  "scripts": {
    "build": "pnpm exec tsc -p tsconfig.build.json",
    "contracts:validate": "node scripts/validate-contracts.mjs && pnpm exec tsx scripts/validate_phase_6b_contracts.mjs",
    "contracts:validate:phase-6b": "pnpm exec tsx scripts/validate_phase_6b_contracts.mjs"
  },
  "dependencies": {
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
