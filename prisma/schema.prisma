datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
  output   = "../apps/api/generated/prisma-client"
}

enum CapabilityRiskLevel {
  low
  medium
  high
  critical
}

enum PermissionScopeType {
  global
  organization
  own_unit
  child_units
  own_record
  assigned_records
}

enum GatekeeperDecisionOutcome {
  ALLOW
  DENY
  APPROVAL_REQUIRED
  STOP_FOR_REVIEW
}

