datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
  output   = "../apps/api/generated/prisma-client"
}

enum CapabilityRiskLevel {
  low
  medium
  high
  critical
}

enum PermissionScopeType {
  global
  organization
  own_unit
  child_units
  own_record
  assigned_records
}

enum GatekeeperDecisionOutcome {
  ALLOW
  DENY
  APPROVAL_REQUIRED
  STOP_FOR_REVIEW
}

model Organization {
  id                          String                     @id @default(cuid())
  slug                        String                     @unique
  display_name                String
  short_name                  String?
  status                      String
  created_at                  DateTime                   @default(now())
  updated_at                  DateTime                   @updatedAt
  organization_domains        OrganizationDomain[]
  unit_types                  UnitType[]
  organization_units          OrganizationUnit[]
  organization_unit_closure   OrganizationUnitClosure[]
  users                       User[]
  groups                      Group[]
  user_groups                 UserGroup[]
  group_capabilities          GroupCapability[]
  audit_logs                  AuditLog[]
  gatekeeper_decision_records GatekeeperDecisionRecord[]
  event_outbox_entries        EventOutbox[]
  read_model_entries          ReadModelEntry[]
  read_model_cursors          ReadModelCursor[]
  engagement_gateway_requests EngagementGatewayRequest[]
  organization_settings       OrganizationSetting[]
  module_lifecycle_events     ModuleLifecycleEvent[]
  workflow_definitions        WorkflowDefinition[]
  workflow_instances          WorkflowInstance[]
  workflow_step_instances     WorkflowStepInstance[]
  file_document_metadata      FileDocumentMetadata[]
  lead_records                LeadRecord[]
  lead_status_history         LeadStatusHistory[]
  lead_assignment_history     LeadAssignmentHistory[]

  // Phase 6B commerce schema baseline relations.
  phase_6b_products                           Phase6BProduct[]
  phase_6b_product_categories                 Phase6BProductCategory[]
  phase_6b_product_media                      Phase6BProductMedia[]
  phase_6b_product_histories                  Phase6BProductHistory[]
  phase_6b_product_price_histories            Phase6BProductPriceHistory[]
  phase_6b_package_definitions                Phase6BPackageDefinition[]
  phase_6b_discount_rules                     Phase6BDiscountRule[]
  phase_6b_inventory_locations                Phase6BInventoryLocation[]
  phase_6b_stock_items                        Phase6BStockItem[]
  phase_6b_stock_movements                    Phase6BStockMovement[]
  phase_6b_lead_sources                       Phase6BLeadSource[]
  phase_6b_lead_evidence                      Phase6BLeadEvidence[]
  phase_6b_lead_match_candidates              Phase6BLeadMatchCandidate[]
  phase_6b_lead_merge_records                 Phase6BLeadMergeRecord[]
  phase_6b_pipeline_stages                    Phase6BPipelineStage[]
  phase_6b_pipeline_timeline_entries          Phase6BPipelineTimelineEntry[]
  phase_6b_communication_templates            Phase6BCommunicationTemplate[]
  phase_6b_communication_attempts             Phase6BCommunicationAttempt[]
  phase_6b_communication_sequence_enrollments Phase6BCommunicationSequenceEnrollment[]
  phase_6b_lead_scores                        Phase6BLeadScore[]
  phase_6b_follow_up_tasks                    Phase6BFollowUpTask[]
  phase_6b_invoices                           Phase6BInvoice[]
  phase_6b_invoice_lines                      Phase6BInvoiceLine[]
  phase_6b_receivables                        Phase6BReceivable[]
  phase_6b_credit_debit_notes                 Phase6BCreditDebitNote[]
  phase_6b_payments                           Phase6BPayment[]
  phase_6b_payment_allocations                Phase6BPaymentAllocation[]
  phase_6b_receipts                           Phase6BReceipt[]
  phase_6b_top_ups                            Phase6BTopUp[]
  phase_6b_reconciliation_candidates          Phase6BReconciliationCandidate[]
  phase_6b_vendors                            Phase6BVendor[]
  phase_6b_expenses                           Phase6BExpense[]
  phase_6b_purchase_orders                    Phase6BPurchaseOrder[]
  phase_6b_purchase_receipts                  Phase6BPurchaseReceipt[]
  phase_6b_chart_of_accounts                  Phase6BChartOfAccount[]
  phase_6b_journal_entries                    Phase6BJournalEntry[]
  phase_6b_journal_entry_lines                Phase6BJournalEntryLine[]
  phase_6b_accounting_periods                 Phase6BAccountingPeriod[]
  phase_6b_tax_mappings                       Phase6BTaxMapping[]
  phase_6b_bank_accounts                      Phase6BBankAccount[]
  phase_6b_bank_transactions                  Phase6BBankTransaction[]
  phase_6b_reconciliation_statements          Phase6BReconciliationStatement[]
  phase_6b_payees                             Phase6BPayee[]
  phase_6b_payroll_batches                    Phase6BPayrollBatch[]
  phase_6b_payroll_payouts                    Phase6BPayrollPayout[]
  phase_6b_billing_operations                 Phase6BBillingOperation[]
  phase_6b_budget_caps                        Phase6BBudgetCap[]

  @@index([status])
}

model OrganizationDomain {
  id              String       @id @default(cuid())
  organization_id String
  domain          String       @unique
  is_primary      Boolean
  verified_at     DateTime?
  organization    Organization @relation(fields: [organization_id], references: [id])

  @@unique([organization_id, domain])
  @@index([organization_id])
  @@index([domain])
}

model UnitType {
  id                 String             @id @default(cuid())
  organization_id    String
  key                String
  label              String
  sort_order         Int
  organization       Organization       @relation(fields: [organization_id], references: [id])
  organization_units OrganizationUnit[] @relation("OrganizationUnit_UnitType")

  @@unique([organization_id, key])
  @@unique([organization_id, id])
  @@index([organization_id])
}

model OrganizationUnit {
  id                      String                    @id @default(cuid())
  organization_id         String
  unit_type_id            String
  parent_unit_id          String?
  key                     String
  name                    String
  status                  String
  organization            Organization              @relation(fields: [organization_id], references: [id])
  unit_type               UnitType                  @relation("OrganizationUnit_UnitType", fields: [organization_id, unit_type_id], references: [organization_id, id])
  parent_unit             OrganizationUnit?         @relation("OrganizationUnit_ParentChild", fields: [organization_id, parent_unit_id], references: [organization_id, id])
  child_units             OrganizationUnit[]        @relation("OrganizationUnit_ParentChild")
  users_primary           User[]                    @relation("User_PrimaryUnit")
  group_capability_scopes GroupCapability[]         @relation("GroupCapability_ScopeUnit")
  lead_records            LeadRecord[]
  closure_as_ancestor     OrganizationUnitClosure[] @relation("OrgUnitClosure_Ancestor")
  closure_as_descendant   OrganizationUnitClosure[] @relation("OrgUnitClosure_Descendant")

  @@unique([organization_id, key])
  @@unique([organization_id, id])
  @@index([organization_id])
  @@index([parent_unit_id])
  @@index([unit_type_id])
}

model OrganizationUnitClosure {
  organization_id    String
  ancestor_unit_id   String
  descendant_unit_id String
  depth              Int
  organization       Organization     @relation(fields: [organization_id], references: [id])
  ancestor_unit      OrganizationUnit @relation("OrgUnitClosure_Ancestor", fields: [organization_id, ancestor_unit_id], references: [organization_id, id])
  descendant_unit    OrganizationUnit @relation("OrgUnitClosure_Descendant", fields: [organization_id, descendant_unit_id], references: [organization_id, id])

  @@id([organization_id, ancestor_unit_id, descendant_unit_id])
  @@index([organization_id, ancestor_unit_id])
  @@index([organization_id, descendant_unit_id])
}

model User {
  id                                   String                     @id @default(cuid())
  organization_id                      String
  email                                String
  display_name                         String
  status                               String
  primary_unit_id                      String?
  organization                         Organization               @relation(fields: [organization_id], references: [id])
  primary_unit                         OrganizationUnit?          @relation("User_PrimaryUnit", fields: [organization_id, primary_unit_id], references: [organization_id, id])
  user_groups                          UserGroup[]                @relation("UserGroup_User")
  audit_logs_as_actor                  AuditLog[]                 @relation("AuditLog_ActorUser")
  gatekeeper_decision_records_as_actor GatekeeperDecisionRecord[] @relation("GatekeeperDecisionRecord_ActorUser")
  module_lifecycle_events_as_actor     ModuleLifecycleEvent[]     @relation("ModuleLifecycleEvent_ActorUser")
  workflow_instances_as_actor          WorkflowInstance[]         @relation("WorkflowInstance_ActorUser")
  workflow_step_instances_as_actor     WorkflowStepInstance[]     @relation("WorkflowStepInstance_ActorUser")
  file_document_metadata_created       FileDocumentMetadata[]     @relation("FileDocumentMetadata_CreatedByUser")
  lead_records_assigned                LeadRecord[]               @relation("LeadRecord_AssignedUser")
  lead_status_history_as_actor         LeadStatusHistory[]        @relation("LeadStatusHistory_ActorUser")
  lead_assignment_history_as_actor     LeadAssignmentHistory[]    @relation("LeadAssignmentHistory_ActorUser")
  lead_assignment_history_as_assigned  LeadAssignmentHistory[]    @relation("LeadAssignmentHistory_AssignedUser")
  engagement_gateway_requests_as_actor EngagementGatewayRequest[] @relation("EngagementGatewayRequest_ActorUser")

  @@unique([organization_id, email])
  @@unique([organization_id, id])
  @@index([organization_id])
  @@index([primary_unit_id])
  @@index([status])
}

model EngagementGatewayRequest {
  id                String       @id @default(cuid())
  organization_id   String
  actor_user_id     String
  source_module     String
  capability_key    String
  request_kind      String
  recipient_ref     String
  payload_json      Json
  idempotency_key   String
  priority          String
  transport_channel String
  status            String
  requested_at      DateTime
  recorded_at       DateTime     @default(now())
  organization      Organization @relation(fields: [organization_id], references: [id])
  actor_user        User         @relation("EngagementGatewayRequest_ActorUser", fields: [organization_id, actor_user_id], references: [organization_id, id])

  @@unique([organization_id, idempotency_key])
  @@index([organization_id, recorded_at])
  @@index([organization_id, actor_user_id, recorded_at])
}

model Group {
  id                 String            @id @default(cuid())
  organization_id    String
  key                String
  label              String
  status             String
  organization       Organization      @relation(fields: [organization_id], references: [id])
  user_groups        UserGroup[]       @relation("UserGroup_Group")
  group_capabilities GroupCapability[] @relation("GroupCapability_Group")

  @@unique([organization_id, key])
  @@unique([organization_id, id])
  @@index([organization_id])
  @@index([status])
}

model UserGroup {
  id              String       @id @default(cuid())
  organization_id String
  user_id         String
  group_id        String
  assigned_at     DateTime     @default(now())
  organization    Organization @relation(fields: [organization_id], references: [id])
  user            User         @relation("UserGroup_User", fields: [organization_id, user_id], references: [organization_id, id])
  group           Group        @relation("UserGroup_Group", fields: [organization_id, group_id], references: [organization_id, id])

  @@unique([organization_id, user_id, group_id])
  @@index([organization_id, user_id])
  @@index([organization_id, group_id])
}

model Capability {
  key                     String              @id
  module_key              String
  description             String
  risk_level              CapabilityRiskLevel
  gatekeeper_required     Boolean
  approval_chain_required Boolean
  group_capabilities      GroupCapability[]

  @@index([module_key])
  @@index([risk_level])
}

model GroupCapability {
  id              String              @id @default(cuid())
  organization_id String
  group_id        String
  capability_key  String
  scope_type      PermissionScopeType
  scope_unit_id   String?
  organization    Organization        @relation(fields: [organization_id], references: [id])
  group           Group               @relation("GroupCapability_Group", fields: [organization_id, group_id], references: [organization_id, id])
  capability      Capability          @relation(fields: [capability_key], references: [key])
  scope_unit      OrganizationUnit?   @relation("GroupCapability_ScopeUnit", fields: [organization_id, scope_unit_id], references: [organization_id, id])

  @@unique([organization_id, group_id, capability_key, scope_type, scope_unit_id])
  @@index([organization_id, group_id])
  @@index([organization_id, capability_key])
  @@index([scope_unit_id])
}

model AuditLog {
  id              String       @id @default(cuid())
  organization_id String
  actor_user_id   String
  action_key      String
  entity_type     String
  entity_id       String
  created_at      DateTime     @default(now())
  metadata        Json
  organization    Organization @relation(fields: [organization_id], references: [id])
  actor_user      User         @relation("AuditLog_ActorUser", fields: [organization_id, actor_user_id], references: [organization_id, id])

  @@index([organization_id, created_at])
  @@index([actor_user_id])
  @@index([entity_type, entity_id])
}

model GatekeeperDecisionRecord {
  id                  String                    @id @default(cuid())
  organization_id     String
  actor_user_id       String
  request_id          String
  capability_key      String
  module_key          String
  entity_type         String
  entity_id           String?
  scope_unit_id       String?
  action_key          String
  outcome             GatekeeperDecisionOutcome
  reason_summary      Json
  check_results       Json
  required_evidence   Json
  missing_evidence    Json
  approval_chain_key  String?
  approval_request_id String?
  decision_token      String?
  correlation_id      String?
  requested_at        DateTime
  recorded_at         DateTime                  @default(now())
  expires_at          DateTime?
  payload             Json
  organization        Organization              @relation(fields: [organization_id], references: [id])
  actor_user          User                      @relation("GatekeeperDecisionRecord_ActorUser", fields: [organization_id, actor_user_id], references: [organization_id, id])

  @@unique([organization_id, request_id])
  @@index([organization_id, outcome, recorded_at])
  @@index([organization_id, actor_user_id, recorded_at])
  @@index([organization_id, capability_key, recorded_at])
  @@index([correlation_id])
}

model EventOutbox {
  id               String       @id @default(cuid())
  organization_id  String
  idempotency_key  String
  event_type       String
  version          String
  event_id         String?
  producer         String       @default("akti-api")
  occurred_at      DateTime     @default(now())
  schema_version   String       @default("1.0.0")
  source_module    String       @default("platform")
  subject          Json?
  payload          Json
  privacy_class    String       @default("internal")
  retention_class  String       @default("standard")
  redaction_policy String       @default("standard")
  audit_required   Boolean      @default(true)
  replay_allowed   Boolean      @default(true)
  status           String
  attempt_count    Int          @default(0)
  next_attempt_at  DateTime?
  last_error       String?
  dead_lettered_at DateTime?
  locked_at        DateTime?
  locked_by        String?
  created_at       DateTime     @default(now())
  processed_at     DateTime?
  organization     Organization @relation(fields: [organization_id], references: [id])

  @@unique([organization_id, idempotency_key])
  @@index([organization_id, status, created_at])
  @@index([organization_id, status, next_attempt_at, created_at])
  @@index([organization_id, dead_lettered_at])
  @@index([event_type])
  @@index([event_id])
  @@index([organization_id, event_type, created_at])
  @@index([organization_id, source_module, created_at])
  @@index([organization_id, schema_version, created_at])
}

model ReadModelEntry {
  id                       String       @id @default(cuid())
  organization_id          String
  read_model_key           String
  source_event_id          String
  source_event_type        String
  source_event_version     String
  source_event_occurred_at DateTime
  source_event_cursor      String
  subject_type             String
  subject_id               String?
  payload                  Json
  privacy_class            String       @default("internal")
  retention_class          String       @default("standard")
  created_at               DateTime     @default(now())
  updated_at               DateTime     @updatedAt
  organization             Organization @relation(fields: [organization_id], references: [id])

  @@unique([organization_id, read_model_key, source_event_id])
  @@unique([organization_id, id])
  @@index([organization_id, read_model_key, updated_at])
  @@index([organization_id, source_event_cursor])
  @@index([organization_id, source_event_type, source_event_occurred_at])
  @@index([organization_id, subject_type, subject_id])
}

model ReadModelCursor {
  id                     String       @id @default(cuid())
  organization_id        String
  read_model_key         String
  source_module          String
  event_type             String
  cursor_value           String
  last_event_id          String?
  last_event_occurred_at DateTime?
  processed_at           DateTime     @default(now())
  updated_at             DateTime     @updatedAt
  organization           Organization @relation(fields: [organization_id], references: [id])

  @@unique([organization_id, read_model_key, source_module, event_type])
  @@unique([organization_id, id])
  @@index([organization_id, read_model_key, updated_at])
  @@index([organization_id, cursor_value])
}

model WorkflowDefinition {
  id                      String                   @id @default(cuid())
  organization_id         String
  workflow_key            String
  version                 String
  owner                   String
  tenant_scope            String
  status                  String
  definition_json         Json
  capability_requirements Json
  emitted_events          Json
  audit_hooks             Json
  evidence_requirements   Json
  deprecation_policy      Json
  search_vector           Unsupported("tsvector")?
  created_at              DateTime                 @default(now())
  updated_at              DateTime                 @updatedAt
  organization            Organization             @relation(fields: [organization_id], references: [id])
  workflow_instances      WorkflowInstance[]

  @@unique([organization_id, workflow_key, version])
  @@unique([organization_id, id])
  @@index([organization_id, workflow_key, status])
  @@index([organization_id, status])
  @@index([owner])
}

model WorkflowInstance {
  id                     String                   @id @default(cuid())
  organization_id        String
  workflow_definition_id String
  workflow_key           String
  version                String
  status                 String
  current_state          String
  subject_type           String
  subject_id             String?
  actor_user_id          String
  correlation_id         String?
  context                Json
  search_vector          Unsupported("tsvector")?
  started_at             DateTime                 @default(now())
  completed_at           DateTime?
  updated_at             DateTime                 @updatedAt
  organization           Organization             @relation(fields: [organization_id], references: [id])
  workflow_definition    WorkflowDefinition       @relation(fields: [organization_id, workflow_definition_id], references: [organization_id, id])
  actor_user             User                     @relation("WorkflowInstance_ActorUser", fields: [organization_id, actor_user_id], references: [organization_id, id])
  workflow_steps         WorkflowStepInstance[]

  @@unique([organization_id, id])
  @@index([organization_id, workflow_key, status])
  @@index([organization_id, actor_user_id, started_at])
  @@index([organization_id, subject_type, subject_id])
  @@index([correlation_id])
}

model WorkflowStepInstance {
  id                    String                     @id @default(cuid())
  organization_id       String
  workflow_instance_id  String
  step_key              String
  state_key             String
  status                String
  action_key            String
  actor_user_id         String?
  gatekeeper_request_id String?
  gatekeeper_outcome    GatekeeperDecisionOutcome?
  evidence_ref          String?
  event_ref             String?
  started_at            DateTime                   @default(now())
  completed_at          DateTime?
  metadata              Json
  organization          Organization               @relation(fields: [organization_id], references: [id])
  workflow_instance     WorkflowInstance           @relation(fields: [organization_id, workflow_instance_id], references: [organization_id, id])
  actor_user            User?                      @relation("WorkflowStepInstance_ActorUser", fields: [organization_id, actor_user_id], references: [organization_id, id])

  @@unique([organization_id, workflow_instance_id, step_key])
  @@index([organization_id, workflow_instance_id, started_at])
  @@index([organization_id, action_key, started_at])
  @@index([organization_id, gatekeeper_outcome, started_at])
  @@index([event_ref])
}

model FileDocumentMetadata {
  id                 String       @id @default(cuid())
  organization_id    String
  file_key           String
  storage_key        String
  owner_module       String
  owner_entity_type  String?
  owner_entity_id    String?
  display_name       String
  mime_type          String
  byte_size          Int
  checksum_sha256    String?
  classification     String
  retention_policy   String
  access_policy      Json
  storage_provider   String
  status             String
  created_by_user_id String?
  created_at         DateTime     @default(now())
  updated_at         DateTime     @updatedAt
  deleted_at         DateTime?
  organization       Organization @relation(fields: [organization_id], references: [id])
  created_by_user    User?        @relation("FileDocumentMetadata_CreatedByUser", fields: [organization_id, created_by_user_id], references: [organization_id, id])

  @@unique([organization_id, file_key])
  @@unique([organization_id, storage_key])
  @@unique([organization_id, id])
  @@index([organization_id, owner_module, created_at])
  @@index([organization_id, owner_entity_type, owner_entity_id])
  @@index([organization_id, classification, created_at])
  @@index([organization_id, status, created_at])
  @@index([organization_id, created_by_user_id, created_at])
}

model ModuleRegistryEntry {
  module_key       String                 @id
  display_name     String
  version          String
  status           String
  manifest_hash    String
  lifecycle_events ModuleLifecycleEvent[]

  @@index([status])
  @@index([version])
  @@index([status, version])
}

model ModuleLifecycleEvent {
  id              String              @id @default(cuid())
  organization_id String?
  module_key      String
  from_status     String?
  to_status       String
  action_key      String
  actor_user_id   String?
  evidence_ref    String?
  reason          String?
  metadata        Json
  created_at      DateTime            @default(now())
  module          ModuleRegistryEntry @relation(fields: [module_key], references: [module_key])
  organization    Organization?       @relation(fields: [organization_id], references: [id])
  actor_user      User?               @relation("ModuleLifecycleEvent_ActorUser", fields: [organization_id, actor_user_id], references: [organization_id, id])

  @@index([module_key, to_status, created_at])
  @@index([organization_id, module_key, created_at])
  @@index([organization_id, actor_user_id, created_at])
  @@index([action_key, created_at])
}

model OrganizationSetting {
  id              String       @id @default(cuid())
  organization_id String
  key             String
  value_json      Json
  updated_at      DateTime     @updatedAt
  organization    Organization @relation(fields: [organization_id], references: [id])

  @@unique([organization_id, key])
  @@index([organization_id])
}

model LeadRecord {
  id                   String                  @id @default(cuid())
  organization_id      String
  organization_unit_id String?
  source_ref           String
  full_name            String
  phone_e164           String
  notes                String?
  status               String
  assigned_user_id     String?
  created_at           DateTime                @default(now())
  updated_at           DateTime                @updatedAt
  organization         Organization            @relation(fields: [organization_id], references: [id])
  assigned_user        User?                   @relation("LeadRecord_AssignedUser", fields: [organization_id, assigned_user_id], references: [organization_id, id])
  organization_unit    OrganizationUnit?       @relation(fields: [organization_id, organization_unit_id], references: [organization_id, id])
  status_history       LeadStatusHistory[]
  assignment_history   LeadAssignmentHistory[]

  @@unique([organization_id, id])
  @@index([organization_id, created_at])
  @@index([organization_id, organization_unit_id, created_at])
  @@index([organization_id, status, created_at])
  @@index([organization_id, organization_unit_id, status, created_at])
  @@index([organization_id, assigned_user_id, created_at])
  @@index([organization_id, organization_unit_id, assigned_user_id, created_at])
}

model LeadStatusHistory {
  id              String       @id @default(cuid())
  organization_id String
  lead_id         String
  actor_user_id   String
  status          String
  reason          String?
  requested_at    DateTime
  changed_at      DateTime     @default(now())
  organization    Organization @relation(fields: [organization_id], references: [id])
  lead            LeadRecord   @relation(fields: [organization_id, lead_id], references: [organization_id, id])
  actor_user      User         @relation("LeadStatusHistory_ActorUser", fields: [organization_id, actor_user_id], references: [organization_id, id])

  @@index([organization_id, lead_id, changed_at])
  @@index([organization_id, actor_user_id, changed_at])
}

model LeadAssignmentHistory {
  id               String       @id @default(cuid())
  organization_id  String
  lead_id          String
  actor_user_id    String
  assigned_user_id String
  requested_at     DateTime
  changed_at       DateTime     @default(now())
  organization     Organization @relation(fields: [organization_id], references: [id])
  lead             LeadRecord   @relation(fields: [organization_id, lead_id], references: [organization_id, id])
  actor_user       User         @relation("LeadAssignmentHistory_ActorUser", fields: [organization_id, actor_user_id], references: [organization_id, id])
  assigned_user    User         @relation("LeadAssignmentHistory_AssignedUser", fields: [organization_id, assigned_user_id], references: [organization_id, id])

  @@index([organization_id, lead_id, changed_at])
  @@index([organization_id, actor_user_id, changed_at])
  @@index([organization_id, assigned_user_id, changed_at])
}

model Phase6BProduct {
  id                   String   @id @default(cuid())
  organization_id      String
  key                  String
  display_name         String
  status               String   @default("draft")
  source_authority_ref String   @default("6b_commerce_core.md")
