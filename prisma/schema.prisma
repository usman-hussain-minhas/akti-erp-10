model OrganizationDomain {
  id              String       @id @default(cuid())
  organization_id String
  domain          String       @unique
  is_primary      Boolean
  verified_at     DateTime?
  organization    Organization @relation(fields: [organization_id], references: [id])

  @@unique([organization_id, domain])
  @@index([organization_id])
  @@index([domain])
}

model UnitType {
  id                 String             @id @default(cuid())
  organization_id    String
  key                String
  label              String
  sort_order         Int
  organization       Organization       @relation(fields: [organization_id], references: [id])
  organization_units OrganizationUnit[] @relation("OrganizationUnit_UnitType")

  @@unique([organization_id, key])
  @@unique([organization_id, id])
  @@index([organization_id])
}

model OrganizationUnit {
  id                      String                    @id @default(cuid())
  organization_id         String
  unit_type_id            String
  parent_unit_id          String?
  key                     String
  name                    String
  status                  String
  organization            Organization              @relation(fields: [organization_id], references: [id])
  unit_type               UnitType                  @relation("OrganizationUnit_UnitType", fields: [organization_id, unit_type_id], references: [organization_id, id])
  parent_unit             OrganizationUnit?         @relation("OrganizationUnit_ParentChild", fields: [organization_id, parent_unit_id], references: [organization_id, id])
  child_units             OrganizationUnit[]        @relation("OrganizationUnit_ParentChild")
  users_primary           User[]                    @relation("User_PrimaryUnit")
  group_capability_scopes GroupCapability[]         @relation("GroupCapability_ScopeUnit")
  lead_records            LeadRecord[]
  closure_as_ancestor     OrganizationUnitClosure[] @relation("OrgUnitClosure_Ancestor")
  closure_as_descendant   OrganizationUnitClosure[] @relation("OrgUnitClosure_Descendant")

  @@unique([organization_id, key])
  @@unique([organization_id, id])
  @@index([organization_id])
  @@index([parent_unit_id])
  @@index([unit_type_id])
}

model OrganizationUnitClosure {
  organization_id    String
  ancestor_unit_id   String
  descendant_unit_id String
  depth              Int
  organization       Organization     @relation(fields: [organization_id], references: [id])
  ancestor_unit      OrganizationUnit @relation("OrgUnitClosure_Ancestor", fields: [organization_id, ancestor_unit_id], references: [organization_id, id])
  descendant_unit    OrganizationUnit @relation("OrgUnitClosure_Descendant", fields: [organization_id, descendant_unit_id], references: [organization_id, id])

  @@id([organization_id, ancestor_unit_id, descendant_unit_id])
  @@index([organization_id, ancestor_unit_id])
  @@index([organization_id, descendant_unit_id])
}

model User {
  id             String           @id @default(cuid())
  organization_id String
  email          String
  display_name   String
  status         String
  primary_unit_id String?
  organization   Organization     @relation(fields: [organization_id], references: [id])
  primary_unit   OrganizationUnit? @relation("User_PrimaryUnit", fields: [organization_id, primary_unit_id], references: [organization_id, id])
  user_groups    UserGroup[]      @relation("UserGroup_User")
  audit_logs_as_actor AuditLog[]  @relation("AuditLog_ActorUser")
  gatekeeper_decision_records_as_actor GatekeeperDecisionRecord[] @relation("GatekeeperDecisionRecord_ActorUser")
  module_lifecycle_events_as_actor ModuleLifecycleEvent[] @relation("ModuleLifecycleEvent_ActorUser")
  workflow_instances_as_actor WorkflowInstance[] @relation("WorkflowInstance_ActorUser")
  workflow_step_instances_as_actor WorkflowStepInstance[] @relation("WorkflowStepInstance_ActorUser")
  file_document_metadata_created FileDocumentMetadata[] @relation("FileDocumentMetadata_CreatedByUser")
  lead_records_assigned LeadRecord[] @relation("LeadRecord_AssignedUser")
  lead_status_history_as_actor LeadStatusHistory[] @relation("LeadStatusHistory_ActorUser")
  lead_assignment_history_as_actor LeadAssignmentHistory[] @relation("LeadAssignmentHistory_ActorUser")
  lead_assignment_history_as_assigned LeadAssignmentHistory[] @relation("LeadAssignmentHistory_AssignedUser")
  engagement_gateway_requests_as_actor EngagementGatewayRequest[] @relation("EngagementGatewayRequest_ActorUser")

  @@unique([organization_id, email])
  @@unique([organization_id, id])
  @@index([organization_id])
  @@index([primary_unit_id])
  @@index([status])
}

model EngagementGatewayRequest {
  id                String       @id @default(cuid())
  organization_id   String
  actor_user_id     String
  source_module     String
  capability_key    String
  request_kind      String
  recipient_ref     String
  payload_json      Json
  idempotency_key   String
  priority          String
  transport_channel String
  status            String
  requested_at      DateTime
  recorded_at       DateTime     @default(now())
  organization      Organization @relation(fields: [organization_id], references: [id])
  actor_user        User         @relation("EngagementGatewayRequest_ActorUser", fields: [organization_id, actor_user_id], references: [organization_id, id])

  @@unique([organization_id, idempotency_key])
  @@index([organization_id, recorded_at])
  @@index([organization_id, actor_user_id, recorded_at])
}

model Group {
  id                 String            @id @default(cuid())
  organization_id    String
  key                String
  label              String
  status             String
  organization       Organization      @relation(fields: [organization_id], references: [id])
  user_groups        UserGroup[]       @relation("UserGroup_Group")
  group_capabilities GroupCapability[] @relation("GroupCapability_Group")

  @@unique([organization_id, key])
  @@unique([organization_id, id])
  @@index([organization_id])
  @@index([status])
}

model UserGroup {
  id              String       @id @default(cuid())
  organization_id String
  user_id         String
  group_id        String
  assigned_at     DateTime     @default(now())
  organization    Organization @relation(fields: [organization_id], references: [id])
  user            User         @relation("UserGroup_User", fields: [organization_id, user_id], references: [organization_id, id])
  group           Group        @relation("UserGroup_Group", fields: [organization_id, group_id], references: [organization_id, id])

  @@unique([organization_id, user_id, group_id])
  @@index([organization_id, user_id])
  @@index([organization_id, group_id])
}

model Capability {
  key                     String               @id
  module_key              String
  description             String
  risk_level              CapabilityRiskLevel
  gatekeeper_required     Boolean
  approval_chain_required Boolean
  group_capabilities      GroupCapability[]

  @@index([module_key])
  @@index([risk_level])
}

model GroupCapability {
  id              String              @id @default(cuid())
  organization_id String
  group_id        String
  capability_key  String
  scope_type      PermissionScopeType
  scope_unit_id   String?
  organization    Organization        @relation(fields: [organization_id], references: [id])
  group           Group               @relation("GroupCapability_Group", fields: [organization_id, group_id], references: [organization_id, id])
  capability      Capability          @relation(fields: [capability_key], references: [key])
  scope_unit      OrganizationUnit?   @relation("GroupCapability_ScopeUnit", fields: [organization_id, scope_unit_id], references: [organization_id, id])

  @@unique([organization_id, group_id, capability_key, scope_type, scope_unit_id])
  @@index([organization_id, group_id])
  @@index([organization_id, capability_key])
  @@index([scope_unit_id])
}

model AuditLog {
  id              String       @id @default(cuid())
  organization_id String
  actor_user_id   String
  action_key      String
  entity_type     String
  entity_id       String
  created_at      DateTime     @default(now())
  metadata        Json
  organization    Organization @relation(fields: [organization_id], references: [id])
  actor_user      User         @relation("AuditLog_ActorUser", fields: [organization_id, actor_user_id], references: [organization_id, id])

  @@index([organization_id, created_at])
  @@index([actor_user_id])
  @@index([entity_type, entity_id])
}

model GatekeeperDecisionRecord {
  id                  String                    @id @default(cuid())
  organization_id     String
  actor_user_id       String
  request_id          String
  capability_key      String
  module_key          String
  entity_type         String
  entity_id           String?
  scope_unit_id       String?
  action_key          String
  outcome             GatekeeperDecisionOutcome
  reason_summary      Json
  check_results       Json
  required_evidence   Json
  missing_evidence    Json
  approval_chain_key  String?
  approval_request_id String?
  decision_token      String?
  correlation_id      String?
  requested_at        DateTime
  recorded_at         DateTime                  @default(now())
  expires_at          DateTime?
  payload             Json
  organization        Organization              @relation(fields: [organization_id], references: [id])
  actor_user          User                      @relation("GatekeeperDecisionRecord_ActorUser", fields: [organization_id, actor_user_id], references: [organization_id, id])

  @@unique([organization_id, request_id])
  @@index([organization_id, outcome, recorded_at])
  @@index([organization_id, actor_user_id, recorded_at])
  @@index([organization_id, capability_key, recorded_at])
  @@index([correlation_id])
}

model EventOutbox {
  id              String       @id @default(cuid())
  organization_id String
  idempotency_key String
  event_type      String
  version         String
  event_id        String?
  producer        String       @default("akti-api")
  occurred_at     DateTime     @default(now())
  schema_version  String       @default("1.0.0")
  source_module   String       @default("platform")
  subject         Json?
  payload         Json
  privacy_class   String       @default("internal")
  retention_class String       @default("standard")
  redaction_policy String      @default("standard")
  audit_required  Boolean      @default(true)
  replay_allowed  Boolean      @default(true)
  status          String
  attempt_count   Int          @default(0)
  next_attempt_at DateTime?
  last_error      String?
  dead_lettered_at DateTime?
  locked_at       DateTime?
  locked_by       String?
  created_at      DateTime     @default(now())
  processed_at    DateTime?
  organization    Organization @relation(fields: [organization_id], references: [id])

  @@unique([organization_id, idempotency_key])
  @@index([organization_id, status, created_at])
  @@index([organization_id, status, next_attempt_at, created_at])
  @@index([organization_id, dead_lettered_at])
  @@index([event_type])
  @@index([event_id])
  @@index([organization_id, event_type, created_at])
  @@index([organization_id, source_module, created_at])
  @@index([organization_id, schema_version, created_at])
}

model ReadModelEntry {
  id                       String       @id @default(cuid())
  organization_id          String
  read_model_key           String
  source_event_id          String
  source_event_type        String
  source_event_version     String
  source_event_occurred_at DateTime
  source_event_cursor      String
  subject_type             String
  subject_id               String?
  payload                  Json
  privacy_class            String       @default("internal")
  retention_class          String       @default("standard")
  created_at               DateTime     @default(now())
  updated_at               DateTime     @updatedAt
  organization             Organization @relation(fields: [organization_id], references: [id])

  @@unique([organization_id, read_model_key, source_event_id])
  @@unique([organization_id, id])
  @@index([organization_id, read_model_key, updated_at])
  @@index([organization_id, source_event_cursor])
  @@index([organization_id, source_event_type, source_event_occurred_at])
  @@index([organization_id, subject_type, subject_id])
}

model ReadModelCursor {
  id                     String       @id @default(cuid())
  organization_id        String
  read_model_key         String
  source_module          String
  event_type             String
  cursor_value           String
  last_event_id          String?
  last_event_occurred_at DateTime?
  processed_at           DateTime     @default(now())
  updated_at             DateTime     @updatedAt
  organization           Organization @relation(fields: [organization_id], references: [id])

  @@unique([organization_id, read_model_key, source_module, event_type])
  @@unique([organization_id, id])
  @@index([organization_id, read_model_key, updated_at])
  @@index([organization_id, cursor_value])
}

model WorkflowDefinition {
  id                      String             @id @default(cuid())
  organization_id         String
  workflow_key            String
  version                 String
  owner                   String
  tenant_scope            String
  status                  String
  definition_json         Json
  capability_requirements Json
  emitted_events          Json
  audit_hooks             Json
  evidence_requirements   Json
  deprecation_policy      Json
  search_vector           Unsupported("tsvector")?
  created_at              DateTime           @default(now())
  updated_at              DateTime           @updatedAt
  organization            Organization       @relation(fields: [organization_id], references: [id])
  workflow_instances      WorkflowInstance[]

  @@unique([organization_id, workflow_key, version])
  @@unique([organization_id, id])
  @@index([organization_id, workflow_key, status])
  @@index([organization_id, status])
  @@index([owner])
}

model WorkflowInstance {
  id                     String                 @id @default(cuid())
  organization_id        String
  workflow_definition_id String
  workflow_key           String
  version                String
  status                 String
  current_state          String
  subject_type           String
  subject_id             String?
  actor_user_id          String
  correlation_id         String?
  context                Json
  search_vector          Unsupported("tsvector")?
  started_at             DateTime               @default(now())
  completed_at           DateTime?
  updated_at             DateTime               @updatedAt
  organization           Organization           @relation(fields: [organization_id], references: [id])
  workflow_definition    WorkflowDefinition     @relation(fields: [organization_id, workflow_definition_id], references: [organization_id, id])
